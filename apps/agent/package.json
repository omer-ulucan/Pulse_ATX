{
  "name": "@pulse-atx/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --external:@supabase/supabase-js --external:dotenv --external:pino --external:yaml --external:zod --outfile=dist/index.js --sourcemap",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pulse-atx/database-types": "workspace:*",
    "@pulse-atx/prompts": "workspace:*",
    "@pulse-atx/schemas": "workspace:*",
    "@pulse-atx/shared": "workspace:*",
    "@supabase/supabase-js": "2.80.0",
    "dotenv": "17.2.3",
    "openai": "6.16.0",
    "pino": "9.14.0",
    "yaml": "2.8.1",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "esbuild": "0.25.12",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.0.8"
  }
}
