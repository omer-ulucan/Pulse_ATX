# Browser-safe Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_AGENT_CONTROL_URL=http://127.0.0.1:8787

# Server-only Supabase configuration
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Nemotron served through vLLM
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=
NEMOTRON_MODEL=nemotron-3-nano

# OpenAI-compatible embedding endpoint
EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# HiddenLayer Runtime Security
HIDDENLAYER_BASE_URL=https://api.hiddenlayer.ai
HIDDENLAYER_AUTH_URL=https://auth.hiddenlayer.ai
HIDDENLAYER_CLIENT_ID=
HIDDENLAYER_CLIENT_SECRET=
# Optional legacy credential; client credentials above are preferred.
HIDDENLAYER_API_KEY=

# Public feeds
AUSTIN_TRAFFIC_FEED_URL=https://data.austintexas.gov/resource/dx9v-zd7x.json
CAPMETRO_FEED_URL=https://data.texas.gov/download/9zu9-jwr2/text/plain
NOAA_ALERTS_URL=https://api.weather.gov/alerts/active?area=TX

# Runtime
DEMO_MODE=true
DEMO_SECRET=
DEMO_OPERATOR=Austin Emergency Operations Center
INCIDENT_COMMANDER_DEMO_AUTO_APPROVE=true
CONTROL_SERVER_ENABLED=false
CONTROL_SERVER_HOST=127.0.0.1
CONTROL_SERVER_PORT=8787
CONTROL_ALLOWED_ORIGIN=http://localhost:3000
WORKER_ID=pulse-atx-local
LOG_LEVEL=info
NEMOCLAW_SANDBOX_NAME=pulse-atx
OPENSHELL_LIVE_CONTAINMENT=false
HEARTBEAT_INTERVAL_MS=5000
TRAFFIC_POLL_INTERVAL_MS=10000
TRANSIT_POLL_INTERVAL_MS=30000
WEATHER_POLL_INTERVAL_MS=60000
STALE_JOB_AFTER_MS=120000
MISSION_CLAIM_LIMIT=4
MISSION_CONCURRENCY=2
MISSION_LEASE_SECONDS=60
MISSION_MAX_LIFETIME_MS=14400000
MISSION_MAX_TOOL_EXECUTIONS_PER_WAKE=12
