{
  "name": "pulse-atx",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "dev:agent": "pnpm --filter @pulse-atx/agent dev",
    "dev:web": "pnpm --filter @pulse-atx/web dev",
    "demo:malicious": "pnpm --filter @pulse-atx/scripts exec tsx inject-malicious-event.ts",
    "demo:replay": "pnpm --filter @pulse-atx/scripts exec tsx replay-incidents.ts",
    "evaluate:learning": "pnpm --filter @pulse-atx/scripts exec tsx evaluate-learning.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.4"
  }
}
